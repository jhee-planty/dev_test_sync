{
  "id": 191,
  "command": "run-scenario",
  "params": {
    "steps": [
      {
        "action": "navigate",
        "url": "https://gemini.google.com/app",
        "wait": 5000
      },
      {
        "action": "open_devtools",
        "tab": "Network"
      },
      {
        "action": "clear_network"
      },
      {
        "action": "type_prompt",
        "service": "gemini3",
        "prompt": "오늘 날씨 알려줘",
        "submit": true,
        "notes": "민감 키워드가 아닌 일반 프롬프트 — 정상 응답 캡처 목적"
      },
      {
        "action": "wait",
        "duration": 8000,
        "notes": "StreamGenerate 응답 완료 대기"
      },
      {
        "action": "capture_network_response",
        "filter": "StreamGenerate",
        "capture": {
          "response_headers": true,
          "response_body_first_500_bytes": true,
          "request_headers": true,
          "status_code": true
        },
        "notes": "StreamGenerate 응답의 Content-Type, 바디 형식(wrb.fr 구조), function ID 확인"
      }
    ],
    "capture_console": true
  },
  "notes": "3-Strike Rule: Gemini StreamGenerate 실제 응답 포맷 캡처. B14/B15/B16 3회 연속 실패 후 접근법 재검토를 위해 실제 응답 구조를 확인. 특히 Content-Type, wrb.fr function ID, 보안헤더 형식이 현재 코드와 일치하는지 검증. DevTools Network에서 StreamGenerate 응답 헤더와 바디 첫 500바이트를 캡처해주세요.",
  "created_at": "2026-04-03T16:40:00+09:00"
}
