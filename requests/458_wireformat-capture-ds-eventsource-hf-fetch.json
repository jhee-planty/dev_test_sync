{
  "id": "458",
  "command": "run-scenario",
  "priority": "high",
  "description": "Wireformat capture for DeepSeek (EventSource override) and HuggingFace (fetch interceptor). Goal: capture the exact raw bytes the browser receives for a normal successful chat response, so we can reverse-engineer the template format.",
  "scenarios": [
    {
      "service_name": "deepseek",
      "url": "https://chat.deepseek.com",
      "capture_method": "EventSource + XHR override",
      "steps": [
        "Open DevTools Console BEFORE navigating",
        "Inject this interceptor BEFORE sending any chat:",
        "```javascript",
        "// Override EventSource to capture SSE",
        "(function(){",
        "  window.__ds = {chunks:[], raw:[], msgCount:0};",
        "  const OrigES = window.EventSource;",
        "  window.EventSource = function(url, opts) {",
        "    const es = new OrigES(url, opts);",
        "    const origOnMsg = null;",
        "    es.addEventListener('message', function(e) {",
        "      window.__ds.chunks.push(e.data);",
        "      window.__ds.msgCount++;",
        "    });",
        "    es.addEventListener('open', function() { window.__ds.raw.push('OPEN:'+url); });",
        "    es.addEventListener('error', function(e) { window.__ds.raw.push('ERROR:'+JSON.stringify(e)); });",
        "    return es;",
        "  };",
        "  // Also override XHR for streaming",
        "  const origXHROpen = XMLHttpRequest.prototype.open;",
        "  const origXHRSend = XMLHttpRequest.prototype.send;",
        "  XMLHttpRequest.prototype.open = function(method, url) {",
        "    this.__url = url;",
        "    return origXHROpen.apply(this, arguments);",
        "  };",
        "  XMLHttpRequest.prototype.send = function(body) {",
        "    if (this.__url && this.__url.includes('chat')) {",
        "      this.addEventListener('progress', function() {",
        "        window.__ds.raw.push('XHR_PROGRESS:'+this.__url+':len='+this.responseText.length);",
        "        if (!window.__ds.xhrResponse) window.__ds.xhrResponse = '';",
        "        window.__ds.xhrResponse = this.responseText;",
        "      });",
        "    }",
        "    return origXHRSend.apply(this, arguments);",
        "  };",
        "  document.title = 'DS_CAPTURE_READY';",
        "})();",
        "```",
        "Wait for DS_CAPTURE_READY title",
        "Type a simple prompt: 'What is 2+2? Reply in one short sentence.'",
        "Wait for response to complete",
        "Capture: JSON.stringify({chunks: window.__ds.chunks.slice(0,10), raw: window.__ds.raw, msgCount: window.__ds.msgCount, xhrLen: (window.__ds.xhrResponse||'').length, xhrFirst500: (window.__ds.xhrResponse||'').substring(0,500)})",
        "ALSO capture from DevTools Network tab: filter by 'completion' or 'chat', find the SSE/streaming request, note the Response Headers (Content-Type, Transfer-Encoding) and first 500 chars of Response body",
        "Save all captured data"
      ]
    },
    {
      "service_name": "huggingface",
      "url": "https://huggingface.co/chat",
      "capture_method": "fetch interceptor (confirmed working from #454)",
      "steps": [
        "Open DevTools Console BEFORE navigating",
        "Inject fetch interceptor:",
        "```javascript",
        "(function(){",
        "  window.__hf = {responses:[], chunks:[]};",
        "  const origFetch = window.fetch;",
        "  window.fetch = async function() {",
        "    const resp = await origFetch.apply(this, arguments);",
        "    const url = arguments[0]?.url || arguments[0] || '';",
        "    if (url.toString().includes('conversation')) {",
        "      const cloned = resp.clone();",
        "      const reader = cloned.body.getReader();",
        "      const decoder = new TextDecoder();",
        "      let fullBody = '';",
        "      try {",
        "        while(true) {",
        "          const {done, value} = await reader.read();",
        "          if (done) break;",
        "          const text = decoder.decode(value, {stream:true});",
        "          fullBody += text;",
        "          window.__hf.chunks.push(text);",
        "        }",
        "      } catch(e) {}",
        "      window.__hf.responses.push({url: url.toString().substring(0,200), contentType: resp.headers.get('content-type'), status: resp.status, bodyLen: fullBody.length, first500: fullBody.substring(0,500), last200: fullBody.substring(fullBody.length-200)});",
        "    }",
        "    return resp;",
        "  };",
        "  document.title = 'HF_CAPTURE_READY';",
        "})();",
        "```",
        "Wait for HF_CAPTURE_READY title",
        "Type a simple prompt: 'What is 2+2? Reply in one short sentence.'",
        "Wait for response to complete",
        "Capture: JSON.stringify({responses: window.__hf.responses, chunkCount: window.__hf.chunks.length, firstChunk: window.__hf.chunks[0], lastChunk: window.__hf.chunks[window.__hf.chunks.length-1]})",
        "Save captured data"
      ]
    }
  ],
  "output_requirements": {
    "for_each_service": [
      "Content-Type header of the streaming response",
      "Transfer-Encoding header",
      "First 500 bytes of response body (exact raw text)",
      "Last 200 bytes of response body",
      "Total response size in bytes",
      "Number of SSE events or NDJSON lines",
      "Event/line separator format (\\n\\n for SSE, \\n for NDJSON)",
      "First complete event/line structure"
    ]
  }
}
