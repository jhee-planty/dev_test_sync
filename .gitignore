# === Git 공유 대상 ===
# requests/    — dev→test 작업 요청
# results/     — test→dev 결과
# scripts/     — 양쪽 자동화 스크립트
# shared-skills/ — 스킬 배포 (test PC 참조)
# .gitignore

# === 로컬 전용 (Git 미공유) ===
archive/
local_archive/
docs/
sql/

# OS files
.DS_Store
Thumbs.db

# 대용량 임시 파일
*.har
*.log

# Compressed archives (local only)
*.tar.gz

# Python cache
__pycache__/
*.pyc

# Skill backups (Git handles versioning)
_backup_*/
*.bak

# Editor
*.swp
*.swo
*~
queue.json
results/files/
