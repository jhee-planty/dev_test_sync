# === Git 공유 대상 ===
# requests/    — dev→test 작업 요청
# results/     — test→dev 결과
# shared-skills/ — 스킬 배포 (test PC 참조)
# .gitignore

# === 로컬 전용 (Git 미공유) ===
archive/
local_archive/
docs/
sql/
artifacts/

# === dev_test_sync 목적 외 디렉토리 차단 (2026-05-13) ===
# DB dumps / dev scripts / files 는 별도 위치에 둔다.
# - DB dumps → local_archive/backups/ (이미 gitignored 위 local_archive/ rule)
# - dev scripts → claude_work/projects/apf-operation/scripts/
# - test PC 산출물 → results/files/ (이미 위 results/files/ rule)
backups/
scripts/
/files/

# OS files
.DS_Store
Thumbs.db

# 대용량 임시 파일
*.har
*.log

# Compressed archives (local only)
*.tar.gz

# Python cache
__pycache__/
*.pyc

# Skill backups (Git handles versioning)
_backup_*/
*.bak
*.bak-*
*.disabled-*
*.drift-backup-*

# Editor
*.swp
*.swo
*~
queue.json
results/files/
