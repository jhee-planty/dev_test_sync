t| \\\\\\\"personal site\\\\\\\"\\\\n\\\\t| \\\\\\\"linkedin profile\\\\\\\"\\\\n\\\\t| \\\\\\\"financial report\\\\\\\"\\\\n\\\\nexport type WebSearchInput = {\\\\n\\\\t// Search queries to find relevant information on the web. Use natural language and include key terms.\\\\n\\\\t// For a single query, still pass a one-item array (e.g. [\\\\\\\"Notion AI\\\\\\\"]). Do not use \\\\\\\"query\\\\\\\".\\\\n\\\\tqueries: string[]\\\\n\\\\t// Optional category filter (e.g., \\\\\\\"news\\\\\\\", \\\\\\\"research paper\\\\\\\", \\\\\\\"github\\\\\\\").\\\\n\\\\tcategory?: WebSearchCategory\\\\n\\\\t// Optional domain allowlist. Only return results from these domains.\\\\n\\\\tincludeDomains?: string[]\\\\n\\\\t// Optional domain blocklist. Omit results from these domains.\\\\n\\\\texcludeDomains?: string[]\\\\n\\\\t// Optional list of required terms. Results should include these phrases.\\\\n\\\\tincludeText?: string[]\\\\n\\\\t// Optional list of excluded terms. Results should not include these phrases.\\\\n\\\\texcludeText?: string[]\\\\n}\\\\n\\\\nexport type WebSearchResult = {\\\\n\\\\turl: string\\\\n\\\\ttitle: string\\\\n\\\\ttext: string\\\\n\\\\tlastEdited?: string\\\\n\\\\tscore?: number\\\\n\\\\tfavicon?: string\\\\n}\\\\n\\\\nexport type WebSearchOutput = {\\\\n\\\\tresults: Array<Array<WebSearchResult>>\\\\n}\\\\n\\\\nexport type WebLoadPageInput = {\\\\n\\\\turl: string\\\\n\\\\t// When true (default), uses fast extraction. When false, uses comprehensive extraction (slow, can take up to a minute). Always use fast_mode first and only set to false if fast mode returned insufficient content.\\\\n\\\\tfast_mode?: boolean\\\\n\\\\t// When true (default), returns the full page content. When false, returns only relevant snippets/highlights matching the provided queries. Set to false with queries for faster, more targeted results.\\\\n\\\\tinclude_full_content?: boolean\\\\n\\\\t// Search queries to focus content extraction on. Required when include_full_content is false. Each query targets specific information to extract from the page.\\\\n\\\\tqueries?: string[]\\\\n\\\\t// 1-based line number to start returning content from (defaults to 1).\\\\n\\\\tline_start?: number\\\\n}\\\\n\\\\nexport type WebPage = {\\\\n\\\\turl: string\\\\n\\\\ttitle: string | null\\\\n\\\\ttext?: string\\\\n\\\\tsummary?: string\\\\n\\\\tpublishedDate?: string\\\\n\\\\tscore: number\\\\n\\\\thighlights?: string[]\\\\n\\\\t// Line-based truncation metadata for text content.\\\\n\\\\tincludedLineCount: number\\\\n\\\\ttotalLineCount: number\\\\n\\\\tisTruncated: boolean\\\\n\\\\tstartLine: number\\\\n\\\\tendLine: number\\\\n}\\\\n\\\\nexport type Search = (args: WebSearchInput) => Promise<WebSearchOutput>\\\\n\\\\nexport type LoadPage = (args: WebLoadPageInput) => Promise<WebPage>\\\\n\\\\nexport type Module = {\\\\n\\\\tsearch: Search\\\\n\\\\tloadPage: LoadPage\\\\n}\\\\n\\\\n// Permissions\\\\nexport type {\\\\n\\\\tModulePermissions,\\\\n\\\\tModuleState,\\\\n\\\\tWebIntegration,\\\\n\\\\tWebModulePermissionAiConfigurable,\\\\n} from \\\\\\\"./integration\\\\\\\"\\\\n\\\"}]}\",\"headerLabel\":[[\"도구 웹개 불러옴\"]]},\"moduleInfo\":{\"id\":\"bc98da72-0be3-4971-881b-6a3c951e0103\",\"name\":\"fs-module\",\"type\":\"fs\"},\"finishedAt\":1774939618833,\"threadOperations\":[],\"renderedResultArtifactPointer\":{\"table\":\"workflow_artifact\",\"id\":\"3347e0fa-91d4-8131-97fb-00af56598c7f\",\"spaceId\":\"a03cc8d8-e491-4254-b3c2-a8aca519ca6f\"}},\"parent_id\":\"3347e0fa-91d4-80df-ae0a-00a9771c4917\",\"parent_table\":\"thread\",\"created_by_id\":\"e014cded-a4d9-4746-ac24-eeb356b09833\",\"created_by_table\":\"notion_user\",\"created_time\":1774939620935,\"data\":{\"inference_id\":\"b77e346d-6379-43b4-aa5d-ac6d37911896\",\"completed\":true,\"completed_time\":1774939622797}},\"role\":\"editor\"}},\"3347e0fa-91d4-8124-9fb3-00aa1f686d84\":{\"spaceId\":\"a03cc8d8-e491-4254-b3c2-a8aca519ca6f\",\"value\":{\"value\":{\"id\":\"3347e0fa-91d4-8124-9fb3-00aa1f686d84\",\"